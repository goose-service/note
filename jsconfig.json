{
  "compilerOptions": {
    "lib": [ "ESNext", "DOM", "DOM.Iterable" ],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "strict": false,
    "jsx": "preserve"
  },
  "include": [
    "client/**/*.js",
    "client/**/*.vue",
    "server/**/*.js",
    "server/**/*.jsx",
    "plugins/**/*.js",
    "vite.config.js"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
